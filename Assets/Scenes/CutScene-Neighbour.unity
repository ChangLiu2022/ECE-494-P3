--- !u!114 &17717167
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 17717160}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5647221eb96db254fbea0d8b6c5c68a6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  lines:
  - speakerName: Neighbour
    speakerSprite: {fileID: 21300000, guid: 81bcb46a2703dbb4a959e443104dae78, type: 3}
    text: Help! My dog was taken by some thugs! There were so many of them, it was
      impossible to take them all at once!
    onShow:
      m_PersistentCalls:
        m_Calls: []
  - speakerName: You
    speakerSprite: {fileID: 21300000, guid: bdcb0a1b982234f47af2bc7b40bc6566, type: 3}
    text: '* Hmm, maybe Mr. Evil is stronger than I thought. I need to get more powerful
      before taking him on... If only I had money to upgrade my weapons....*'
    onShow:
      m_PersistentCalls:
        m_Calls: []
  - speakerName: Neighbour
    speakerSprite: {fileID: 21300000, guid: 81bcb46a2703dbb4a959e443104dae78, type: 3}
    text: Can you help me get my dog back? I saw them take her over to that building.
      I can pay you handsomly!
    onShow:
      m_PersistentCalls:
        m_Calls: []
  - speakerName: You
    speakerSprite: {fileID: 21300000, guid: 384e71ca185df48b89dbb10ed5c12989, type: 3}
    text: Sounds like a plan.
    onShow:
      m_PersistentCalls:
        m_Calls: []
