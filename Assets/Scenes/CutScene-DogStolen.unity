  m_EditorClassIdentifier: 
  lines:
  - speakerName: Evil Inc. Employee
    speakerSprite: {fileID: 21300000, guid: 40f1ae0e702f52a4faa973c4280ff08b, type: 3}
    text: Mr Evil has requested everyone's dog in the area to be taken and used for
      his new wig development. Hand over the pooch, and don't try anything funny.
    onShow:
      m_PersistentCalls:
        m_Calls: []
  - speakerName: You
    speakerSprite: {fileID: 21300000, guid: bdcb0a1b982234f47af2bc7b40bc6566, type: 3}
    text: No! You're not taking my dog from me!
    onShow:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 1649327248}
          m_TargetAssemblyTypeName: DogController, Assembly-CSharp
          m_MethodName: TeleportTo
          m_Mode: 2
          m_Arguments:
            m_ObjectArgument: {fileID: 1777248067}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - speakerName: Dog
    speakerSprite: {fileID: 21300000, guid: 28732efe5187f46d5a39a7ddcafceec8, type: 3}
    text: Woof Woof!
    onShow:
      m_PersistentCalls:
        m_Calls: []
  - speakerName: Evil Inc. Employee
    speakerSprite: {fileID: 21300000, guid: e8e9f3d89195aff45a0703842c14c6e2, type: 3}
    text: You have no choice bub.
    onShow:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 1820800529}
          m_TargetAssemblyTypeName: DogController, Assembly-CSharp
          m_MethodName: TeleportTo
          m_Mode: 2
          m_Arguments:
            m_ObjectArgument: {fileID: 1450134978}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
        - m_Target: {fileID: 1154436231}
          m_TargetAssemblyTypeName: DogController, Assembly-CSharp
          m_MethodName: TeleportTo
          m_Mode: 2
          m_Arguments:
            m_ObjectArgument: {fileID: 1873525283}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.GameObject, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
  - speakerName: You
    speakerSprite: {fileID: 21300000, guid: bdcb0a1b982234f47af2bc7b40bc6566, type: 3}
    text: ...
    onShow:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 573203872}
          m_TargetAssemblyTypeName: BamController, Assembly-CSharp
          m_MethodName: Show
          m_Mode: 1
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
