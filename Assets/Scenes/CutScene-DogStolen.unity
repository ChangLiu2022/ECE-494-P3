  lines:
  - speakerName: Evil Inc. Employee
    speakerSprite: {fileID: 21300000, guid: 40f1ae0e702f52a4faa973c4280ff08b, type: 3}
    text: Mr Evil has requested everyone's dog in the area to be taken and used for
      his new wig development.
    onShow:
      m_PersistentCalls:
        m_Calls: []
  - speakerName: Evil Inc. Employee
    speakerSprite: {fileID: 21300000, guid: 40f1ae0e702f52a4faa973c4280ff08b, type: 3}
    text: Hand over the pooch, and don't try anything funny.
    onShow:
      m_PersistentCalls:
        m_Calls: []
  - speakerName: You
    speakerSprite: {fileID: 21300000, guid: bdcb0a1b982234f47af2bc7b40bc6566, type: 3}
    text: No! You're not taking my dog from me!
    onShow:
      m_PersistentCalls:
